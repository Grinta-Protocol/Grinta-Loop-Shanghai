# Copy this to app/.env and fill in your values
#
# RPC
STARKNET_RPC_URL=https://starknet-sepolia.g.alchemy.com/starknet/version/rpc/v0_10/YOUR_KEY

# Deployer wallet (admin — for oracle cheat controls)
DEPLOYER_ADDRESS=0x...
DEPLOYER_PRIVATE_KEY=0x...

# Agent wallet (for propose_parameters via Guard)
AGENT_ADDRESS=0x1f8975c5a1c6d2764bd30dddf4d6ab80c59e8287e5f796a5ba2490dcbf2dab6
AGENT_PRIVATE_KEY=0x...

# LLM provider (OpenAI-compatible)
LLM_API_KEY=your_key
LLM_BASE_URL=https://api.commonstack.ai/v1
LLM_MODEL=zai-org/glm-5.1

# Contract addresses (V10 + redeployed PID/Guard)
