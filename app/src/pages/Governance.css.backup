/* ═══════════════════════════════════════════
   Grinta Governance — Neoclassical Styles
   ═══════════════════════════════════════════ */

.governance-app {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
}

/* Decorative columns */
.deco-column {
  display: none;
  position: fixed;
  top: 50%;
  transform: translateY(-50%);
  height: 80vh;
  width: auto;
  opacity: 0.04;
  pointer-events: none;
  user-select: none;
}
.deco-left { left: 0; }
.deco-right { right: 0; transform: translateY(-50%) scaleX(-1); }
@media (min-width: 1200px) {
  .deco-column { display: block; }
}

/* Main container */
.gov-main {
  max-width: 1100px;
  margin: 0 auto;
  padding: 2.5rem 1.5rem;
  position: relative;
}

/* ── HEADER ── */
.gov-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1.5rem;
  margin-bottom: 2.5rem;
  flex-wrap: wrap;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 1rem;
}

.philosopher-avatar {
  width: 64px;
  height: 64px;
  object-fit: contain;
  border-radius: 50%;
}

.header-title {
  font-size: 2.5rem;
  font-weight: 600;
  line-height: 1.1;
}

.header-subtitle {
  font-family: var(--font-serif);
  font-style: italic;
  color: var(--text-secondary);
  font-size: 0.95rem;
  margin-top: 0.25rem;
}

.header-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 0.5rem;
}

.network-badge {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.4rem 0.85rem;
  border-radius: 9999px;
  font-size: 0.75rem;
  font-weight: 500;
}

.pulse-dot {
  position: relative;
  display: flex;
  width: 8px;
  height: 8px;
}

.pulse-dot-ping {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  background: var(--success);
  opacity: 0.75;
  animation: ping 1.5s cubic-bezier(0, 0, 0.2, 1) infinite;
}

.pulse-dot-core {
  position: relative;
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--success);
}

@keyframes ping {
  75%, 100% { transform: scale(2); opacity: 0; }
}

.powered-by {
  font-size: 0.65rem;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  color: var(--text-muted);
}

/* ── SECTIONS ── */
.section {
  margin-bottom: 2.5rem;
}

.section-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 1rem;
}

.section-header h2 {
  font-size: 1.6rem;
  font-weight: 600;
}

.section-tag {
  font-size: 0.65rem;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  color: var(--text-muted);
}

/* ── METRICS GRID ── */
.metrics-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 1rem;
  justify-content: center;
}

.metrics-grid > * {
  flex: 1 0 220px;
  max-width: calc(25% - 0.75rem);
}

.metric-card {
  padding: 1.25rem;
  transition: transform 0.2s, box-shadow 0.2s, background-color 1.2s;
}

.metric-card:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-glow-teal);
}

.metric-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 0.75rem;
}

.metric-label {
  font-size: 0.65rem;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--text-muted);
  font-weight: 500;
}

.metric-sublabel {
  font-size: 0.55rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--accent);
  opacity: 0.7;
  margin-top: 0.15rem;
}

.metric-icon {
  font-size: 1.1rem;
  opacity: 0.4;
  color: var(--accent);
}

.metric-value-row {
  display: flex;
  align-items: baseline;
  gap: 0.5rem;
}

.metric-value {
  font-size: 1.6rem;
  font-weight: 600;
  line-height: 1;
}

.metric-trend {
  font-size: 0.85rem;
  font-weight: 500;
}

.tone-success { color: var(--success); }
.tone-warning { color: var(--warning); }
.tone-danger { color: var(--danger); }

/* ── SIMULATION CARD ── */
.sim-card {
  padding: 2rem;
  position: relative;
  overflow: hidden;
}

.sim-glow {
  position: absolute;
  width: 10rem;
  height: 10rem;
  border-radius: 50%;
  filter: blur(60px);
  pointer-events: none;
}
.sim-glow-tl { top: -2.5rem; right: -2.5rem; background: hsl(170, 100%, 36%, 0.06); }
.sim-glow-br { bottom: -2.5rem; left: -2.5rem; background: hsl(43, 52%, 54%, 0.08); }

.sim-header {
  text-align: center;
  margin-bottom: 1.5rem;
  position: relative;
}

.sim-header h2 {
  font-size: 1.6rem;
  font-weight: 600;
  margin-bottom: 0.25rem;
}

.sim-subtitle {
  font-family: var(--font-serif);
  font-style: italic;
  color: var(--text-secondary);
  font-size: 0.9rem;
}

.sim-buttons-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 0.75rem;
  position: relative;
}

.sim-divider {
  height: 1px;
  background: var(--border);
  margin: 1.25rem 0;
}

.sim-agent-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.75rem;
  margin-bottom: 0.75rem;
}

/* Buttons */
.sim-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  padding: 0.85rem 1rem;
  border-radius: var(--radius-sm);
  font-weight: 600;
  font-size: 0.8rem;
  color: white;
  letter-spacing: 0.01em;
  box-shadow: var(--shadow-press);
  transition: all 0.2s;
}

.sim-btn:hover:not(:disabled) {
  transform: translateY(-2px);
  box-shadow: 0 10px 24px hsl(215, 28%, 17%, 0.18);
}

.sim-btn:active:not(:disabled) {
  transform: translateY(1px);
  box-shadow: inset 0 2px 4px hsl(215, 28%, 17%, 0.2);
}

.sim-btn:disabled {
  opacity: 0.55;
  cursor: not-allowed;
  transform: none !important;
}

.sim-crash { background: var(--gradient-crash); }
.sim-pump { background: var(--gradient-pump); }
.sim-reset {
  background: hsl(215, 15%, 55%);
}
.sim-agent {
  background: linear-gradient(135deg, hsl(260, 60%, 55%), hsl(280, 60%, 55%));
}
.sim-swap {
  background: linear-gradient(135deg, hsl(200, 80%, 50%), hsl(210, 80%, 55%));
}
.sim-demo {
  width: 100%;
  padding: 1rem;
  font-size: 0.9rem;
  background: linear-gradient(135deg, hsl(0, 75%, 55%), hsl(260, 60%, 55%), hsl(170, 100%, 36%));
  background-size: 200% 200%;
  animation: gradient-shift 4s ease infinite;
}

@keyframes gradient-shift {
  0%, 100% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
}

/* ── DECISION CARD ── */
.decision-card {
  padding: 1.5rem;
}

.decision-badge {
  display: inline-block;
  padding: 0.3rem 0.85rem;
  border-radius: 6px;
  font-weight: 700;
  font-size: 0.75rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  margin-bottom: 0.75rem;
}

.decision-hold {
  background: var(--bg-muted);
  color: var(--text-secondary);
}
.decision-adjust {
  background: hsl(260, 60%, 55%, 0.12);
  color: hsl(260, 60%, 55%);
}
.decision-adjust_emergency {
  background: hsl(0, 72%, 51%, 0.12);
  color: var(--danger);
}

.agent-quote {
  font-family: var(--font-serif);
  font-style: italic;
  color: var(--text-primary);
  opacity: 0.9;
  font-size: 1.1rem;
  line-height: 1.6;
  border-left: 2px solid var(--gold);
  padding-left: 1rem;
  margin: 0.5rem 0;
}

.decision-params {
  font-size: 0.8rem;
  color: var(--accent);
  margin-top: 0.75rem;
}

/* ── AGENT LOG ── */
.log-card {
  overflow: hidden;
}

.log-titlebar {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.6rem 1rem;
  border-bottom: 1px solid var(--border);
  background: var(--bg-muted);
}

.titlebar-dots {
  display: flex;
  gap: 0.35rem;
}

.dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
}
.dot-red { background: hsl(0, 72%, 51%, 0.6); }
.dot-yellow { background: hsl(38, 92%, 50%, 0.6); }
.dot-green { background: hsl(158, 64%, 42%, 0.6); }

.titlebar-text {
  font-size: 0.7rem;
  color: var(--text-muted);
  margin-left: 0.5rem;
}

.log-scroll {
  height: 420px;
  overflow-y: auto;
  padding: 1.25rem 1.5rem;
  background: linear-gradient(to bottom, hsl(40, 30%, 97%, 0.4), var(--bg-muted));
}

.log-scroll::-webkit-scrollbar {
  width: 6px;
}
.log-scroll::-webkit-scrollbar-track {
  background: transparent;
}
.log-scroll::-webkit-scrollbar-thumb {
  background: var(--border);
  border-radius: 3px;
}

.log-empty {
  color: var(--text-muted);
  font-family: var(--font-serif);
  font-style: italic;
  text-align: center;
  padding: 3rem 0;
}

.log-line {
  display: flex;
  gap: 0.75rem;
  padding: 0.4rem 0;
}

.log-reason {
  padding: 0.6rem 0;
}

.log-time {
  font-size: 0.7rem;
  color: var(--text-muted);
  flex-shrink: 0;
  width: 5rem;
  padding-top: 0.15rem;
}

.log-icon {
  font-size: 1rem;
  flex-shrink: 0;
  line-height: 1.4;
}

.log-content {
  flex: 1;
  min-width: 0;
}

.log-text {
  font-size: 0.85rem;
  color: var(--text-primary);
  opacity: 0.85;
  line-height: 1.5;
}

.tx-link {
  font-size: 0.75rem;
  color: var(--accent) !important;
  text-decoration: underline;
  text-underline-offset: 2px;
}
.tx-link:hover {
  color: var(--accent-hover) !important;
}

/* ── HISTORY TABLE ── */
.table-wrap {
  overflow: hidden;
}

.history-table {
  width: 100%;
  font-size: 0.85rem;
  border-collapse: collapse;
}

.history-table thead {
  background: var(--bg-muted);
}

.history-table th {
  text-align: left;
  padding: 0.75rem 1.25rem;
  font-size: 0.65rem;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--text-muted);
  font-weight: 500;
}

.history-table td {
  padding: 0.75rem 1.25rem;
  border-top: 1px solid var(--border);
}

.history-table tbody tr:hover {
  background: var(--accent-dim);
}

.history-action {
  font-family: var(--font-serif);
  font-style: italic;
}

.table-empty {
  text-align: center;
  color: var(--text-muted);
  font-family: var(--font-serif);
  font-style: italic;
  padding: 2rem 1.25rem !important;
}

/* ── FOOTER ── */
.gov-footer {
  text-align: center;
  font-family: var(--font-serif);
  font-style: italic;
  font-size: 0.85rem;
  color: var(--text-muted);
  margin-top: 3rem;
  padding-bottom: 2rem;
}

/* ── RESPONSIVE ── */
@media (max-width: 900px) {
  .metrics-grid > * {
    max-width: calc(33.333% - 0.667rem);
  }
  .sim-buttons-grid {
    grid-template-columns: repeat(3, 1fr);
  }
  .sim-buttons-grid .sim-reset {
    grid-column: 1 / -1;
  }
}

@media (max-width: 640px) {
  .gov-main {
    padding: 1.5rem 1rem;
  }
  .gov-header {
    flex-direction: column;
    align-items: flex-start;
  }
  .header-right {
    align-items: flex-start;
  }
  .header-title {
    font-size: 1.8rem;
  }
  .metrics-grid > * {
    max-width: calc(50% - 0.5rem);
  }
  .metric-value {
    font-size: 1.2rem;
  }
  .sim-buttons-grid {
    grid-template-columns: 1fr 1fr;
  }
  .sim-agent-row {
    grid-template-columns: 1fr;
  }
}
