# === Starknet ===
STARKNET_RPC_URL=https://starknet-sepolia.public.blastapi.io
AGENT_PRIVATE_KEY=0x...
AGENT_ADDRESS=0x...

# === CommonStack LLM ===
COMMONSTACK_API_KEY=ak-...
COMMONSTACK_MODEL=zai-org/glm-5.1

# === Contract Addresses (from deployed_v10.json) ===
PARAMETER_GUARD_ADDRESS=0x00341ecbc17e27a38d8c3478c9bf98bc4f6f0945de94b5d595f0f495311c83f5
PID_CONTROLLER_ADDRESS=0x058fafc3d6237eb3e09e838bb0f6eee06508dd0c35c730b456a8f6ee2fc6d8f4
GRINTA_HOOK_ADDRESS=0x04560e84979e5bae575c65f9b0be443d91d9333a8f2f50884ebd5aaf89fb6147
SAFE_ENGINE_ADDRESS=0x07417b07b7ac71dd816c8d880f4dc1f74c10911aa174305a9146e1b56ef60272
ORACLE_RELAYER_ADDRESS=0x013f7f3661d81b29c3a55b1022231161c68282537049738dd1676a855063f851

# === Agent Behavior ===
CHECK_INTERVAL_MS=15000
EMERGENCY_DEVIATION_THRESHOLD=0.05

# === Demo Mode (off-chain feed) ===
# If set, the agent reads this CSV and includes off-chain BTC in its prompt,
# simulating a real-time CEX/Pyth feed ahead of the on-chain oracle.
# Leave empty to run in production mode (on-chain only).
DEMO_CSV_PATH=
# Unix epoch ms marking demo t=0. The launcher script writes this so the
# agent + feeder + trader share the same clock. Leave empty for "now".
DEMO_START_TIMESTAMP_MS=
