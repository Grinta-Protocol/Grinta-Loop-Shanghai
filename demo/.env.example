# === Starknet RPC ===
STARKNET_RPC_URL=https://starknet-sepolia.public.blastapi.io

# === Feeder + Trader wallet (deployer — has admin to push to OracleRelayer) ===
# Reuse the deployer wallet from grinta-agentic/.env (STARKNET_ACCOUNT_ADDRESS)
DEPLOYER_ADDRESS=0x072F0D2391F7ce9103D31a64b6A36e0Fe8d32f908D2e183A02d9D46403b21ce2
DEPLOYER_PRIVATE_KEY=0x0308edbd0b0c2d4f93de5968de94e8b530c92365e7c353d5b16198a227006733

# === Deployed contract addresses (from deployed_v9.json — UPDATE AFTER REDEPLOY) ===
ORACLE_RELAYER_ADDRESS=0x004b92a6899e0aea5adfcdd9713e598d1ec05873e4a272adf94ce57558032c0f
GRINTA_HOOK_ADDRESS=0x029d4fa992b69377bdc8fb9f98dd4fb255b7c82e62727be4d5badcd7da60122b
SAFE_ENGINE_ADDRESS=0x012acdb5b9fd6743372f6e14e8af51dae1cd54bbcc578682656f4c75628d8c0c
SAFE_MANAGER_ADDRESS=0x02cd8432c278a395c5e8b6dc19c783d08b6d01a51ca3477d3a6427e183b0c32a
PID_CONTROLLER_ADDRESS=0x05b4901f396b2d3062b38a594a8c61d513a3c32cf9f37be9f391e7dda998441d
WBTC_ADDRESS=0x0530e00b92e75cc7a5f95ffcacb6835167f23b0f646d34d4163ea9e979482e96
USDC_ADDRESS=0x03e977ae5de6e89dba8f188640f519477fade41cedef7fbbc279d86a44bf4874
# GRIT token IS the SAFEEngine itself — same address
GRIT_ADDRESS=0x012acdb5b9fd6743372f6e14e8af51dae1cd54bbcc578682656f4c75628d8c0c

# Filled after ParameterGuard is deployed (post-redeploy)
PARAMETER_GUARD_ADDRESS=

# === Ekubo (for trader bot) ===
EKUBO_ROUTER_ADDRESS=0x0045f933adf0607292468ad1c1dedaa74d5ad166392590e72676a34d01d7b763
EKUBO_CORE_ADDRESS=0x0444a09d96389aa7148f1aada508e30b71299ffe650d9c97fdaae38cb9a23384

# === Pool key (Grinta GRIT/USDC pool — must match deployed_v9.json) ===
POOL_FEE=0
POOL_TICK_SPACING=1000

# === Setup amounts (for one-time bootstrap) ===
# Trader needs USDC and GRIT to make swaps both directions.
SETUP_USDC_MINT=10000000000          # 10,000 USDC (6 decimals)
SETUP_WBTC_MINT=1000000000           # 10 WBTC (8 decimals — adjust to mock's actual)
SETUP_WBTC_DEPOSIT=500000000         # 5 WBTC deposit (50% of mint)
SETUP_GRIT_BORROW=30000000000000000000000  # 30,000 GRIT (18 decimals)

# === Demo throttles to apply via hook setters ===
DEMO_PRICE_INTERVAL=5
DEMO_RATE_INTERVAL=30

# === Agent registration ===
AGENT_ADDRESS_TO_REGISTER=0x27c0daed856e1883d7011e24fd173792268a90e7e7672df3f2b73152ef14905

# === Demo timing (seconds) ===
# Cadence at which feeder pushes CSV BTC price to OracleRelayer.
# Should be > on-chain PRICE_UPDATE_INTERVAL but slow enough to leave room for the agent.
FEEDER_INTERVAL_SEC=10

# Cadence at which trader bot does swaps (depegs GRIT proportionally to BTC drop).
TRADER_INTERVAL_SEC=8

# Path to the synthetic BTC crash CSV (relative to demo/).
CSV_PATH=data/btc_crash.csv

# Total demo duration in seconds (cuts off after this even if CSV has more samples).
DEMO_DURATION_SEC=240
